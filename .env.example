# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgres://user:password@host:port/db-name"

# ── Supabase ──────────────────────────────────────────────────────────────────
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SECRET_KEY="your-service-role-key"

# ── Seeding ───────────────────────────────────────────────────────────────────
# Password used when `pnpm db:seed` creates the demo user (spencer@fork.dev).
# Defaults to "seed-password-123" if not set.
SEED_USER_PASSWORD="seed-password-123"

# ── E2E tests (authenticated flows) ───────────────────────────────────────────
# Must match the seeded user. Without these, authenticated e2e tests are skipped.
E2E_USER_EMAIL="spencer@fork.dev"
E2E_USER_PASSWORD="seed-password-123"
