{
	"name": "recipebook",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"// ── Dev ───────────────────────────────────────────────────────": "",
		"dev": "pnpm compile:force && vite dev",
		"build": "pnpm compile:force && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"// ── Code Quality ────────────────────────────────────────────": "",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"// ── Testing ─────────────────────────────────────────────────": "",
		"test": "pnpm test:unit run && pnpm test:e2e",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"// ── Database ─────────────────────────────────────────────────": "",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/lib/server/db/seed.ts",
		"db:types": "supabase gen types typescript --project-id nqcqdpcczabsadfowrxd --schema public > src/lib/types/database.types.ts",
		"// ── i18n ─────────────────────────────────────────────────────": "",
		"compile:force": "paraglide-js compile --outdir ./src/lib/paraglide",
		"machine-translate": "inlang machine translate --project project.inlang",
		"// ── Storybook ────────────────────────────────────────────────": "",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@eslint/compat": "^1.3.0",
		"@eslint/js": "^9.29.0",
		"@inlang/cli": "^3.0.0",
		"@inlang/paraglide-js": "2.1.0",
		"@playwright/test": "^1.53.0",
		"@sveltejs/adapter-auto": "^6.0.1",
		"@sveltejs/kit": "^2.21.5",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@tailwindcss/vite": "^4.1.10",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.8",
		"@types/diff": "^8.0.0",
		"@types/node": "^22.15.32",
		"@vitest/browser": "3.2.4",
		"@vitest/coverage-v8": "3.2.4",
		"dotenv": "^17.1.0",
		"drizzle-kit": "^0.31.4",
		"eslint": "^9.29.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-svelte": "^3.9.2",
		"globals": "^16.2.0",
		"jsdom": "^26.1.0",
		"mdsvex": "^0.12.6",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.12",
		"svelte": "^5.34.5",
		"svelte-check": "^4.2.1",
		"svelte-preprocess": "^6.0.3",
		"tailwindcss": "^4.1.10",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.34.1",
		"vite": "^6.3.5",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@supabase/ssr": "^0.6.1",
		"@supabase/supabase-js": "^2.50.3",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"bits-ui": "^2.16.3",
		"diff": "^8.0.4",
		"drizzle-orm": "^0.44.2",
		"nanoid": "^5.1.7",
		"postgres": "^3.4.7"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild",
			"svelte-preprocess"
		]
	}
}
